{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["apps/.+/overlays/.+\\.ya?ml"],
      "matchStrings": [
        "digest:\\s*\"?(?<currentDigest>sha256:[a-f0-9]+)\"?\\s*#\\s*renovate:\\s*depName=(?<depName>\\S+)"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
