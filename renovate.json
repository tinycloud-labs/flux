{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/apps/.+/overlays/.+\\.ya?ml/"
      ],
      "matchStrings": [
        "tag:\\s*\"?(?<currentValue>[\\w.-]+)\"?\\s*#\\s*renovate:\\s*depName=(?<depName>\\S+)[\\s\\S]*?digest:\\s*\"?(?<currentDigest>sha256:[a-f0-9]+)\"?",
        "repository:\\s*(?<depName>ghcr\\.io/[\\w-]+/[\\w-]+)[\\s\\S]*?tag:\\s*\"?(?<currentValue>[\\w.-]+)\"?"
      ],
      "datasourceTemplate": "docker",
      "currentValueTemplate": "{{currentDigest}}"
    }
  ]
}
